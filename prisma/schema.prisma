generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model NewsletterSubscriber {
  id           String   @id @default(uuid())
  email        String   @unique
  createdAt    DateTime @default(now())
  consentGiven Boolean

  @@map("newsletter_subscribers")
}
